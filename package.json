{
  "name": "cutlist-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker:dev": "wrangler dev workers/api.ts --local",
    "dev:all": "concurrently -n worker,next -c yellow,cyan \"npm run worker:dev\" \"npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker:deploy": "wrangler deploy workers/api.ts",
    "frontend:build": "opennextjs-cloudflare build",
    "frontend:deploy": "npm run frontend:build && wrangler deploy -c wrangler.frontend.toml",
    "frontend:dev": "npm run frontend:build && wrangler dev -c wrangler.frontend.toml"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "15.2.4",
    "postcss": "^8.5.10",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.6.2",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "concurrently": "^9.1.2",
    "eslint": "9.22.0",
    "eslint-config-next": "15.2.4",
    "typescript": "5.8.2",
    "wrangler": "4.26.0"
  }
}
