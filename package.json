{
  "name": "cutlist-pro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "worker:dev": "wrangler dev workers/api.ts --local",
    "dev:all": "concurrently -n worker,next -c yellow,cyan \"npm run worker:dev\" \"npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "worker:deploy": "wrangler deploy workers/api.ts"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "next": "15.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "concurrently": "^9.1.2",
    "eslint": "9.22.0",
    "eslint-config-next": "15.2.4",
    "typescript": "5.8.2",
    "wrangler": "4.11.1"
  }
}
